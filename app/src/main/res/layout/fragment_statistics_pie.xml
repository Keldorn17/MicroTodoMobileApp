<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="90dp">


        <TextView
            android:id="@+id/tvNoOwnSharedData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No todos available yet"
            android:textColor="#888899"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/pieChartOwnShared"
            app:layout_constraintEnd_toEndOf="@id/pieChartOwnShared"
            app:layout_constraintStart_toStartOf="@id/pieChartOwnShared"
            app:layout_constraintTop_toTopOf="@id/pieChartOwnShared" />
        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChartOwnShared"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_margin="16dp"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/tvNoOwnStatusData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No own todos to analyze"
            android:textColor="#888899"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/pieChartOwnStatus"
            app:layout_constraintEnd_toEndOf="@id/pieChartOwnStatus"
            app:layout_constraintStart_toStartOf="@id/pieChartOwnStatus"
            app:layout_constraintTop_toTopOf="@id/pieChartOwnStatus" />
        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChartOwnStatus"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_margin="16dp"
            app:layout_constraintTop_toBottomOf="@id/pieChartOwnShared" />


        <TextView
            android:id="@+id/tvNoSharedData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No shared todos yet"
            android:textColor="#888899"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/pieChartSharedStatus"
            app:layout_constraintEnd_toEndOf="@id/pieChartSharedStatus"
            app:layout_constraintStart_toStartOf="@id/pieChartSharedStatus"
            app:layout_constraintTop_toTopOf="@id/pieChartSharedStatus" />
        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChartSharedStatus"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_margin="16dp"
            app:layout_constraintTop_toBottomOf="@id/pieChartOwnStatus"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>