<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="90dp">

        <TextView
            android:id="@+id/tvNoGeneralBarData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/statistics_no_general_data"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/barChartGeneral"
            app:layout_constraintEnd_toEndOf="@id/barChartGeneral"
            app:layout_constraintStart_toStartOf="@id/barChartGeneral"
            app:layout_constraintTop_toTopOf="@id/barChartGeneral" />

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChartGeneral"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_margin="24dp"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvNoPriorityData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/statistics_no_priority_data"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/barChartPriorities"
            app:layout_constraintEnd_toEndOf="@id/barChartPriorities"
            app:layout_constraintStart_toStartOf="@id/barChartPriorities"
            app:layout_constraintTop_toTopOf="@id/barChartPriorities" />

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChartPriorities"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_margin="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barChartGeneral" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>